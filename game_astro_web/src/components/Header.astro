---
import DupaLogo from '../assets/my_logo.png';
import { Menu } from 'webcoreui/astro';
import { Select } from 'webcoreui/astro';
import { gameData } from '../lib/gameData';

const menu = [
	{ name: 'Home', href: '/', active: true },
    { name: 'About', href: '/about', active: true }
]

const menuLogo = {
    url: DupaLogo.src,
    width: 100
}
---

<header>
	<Menu items={menu} logo={menuLogo} />
	<Select
		name="select-id"
		itemGroups={[{
			items: 
				Object.values(gameData).map((game) => ({
					name: game.title,
					href: game.href,
				}))
		}]}
		showSearchBar={true}
		showSearchBarIcon={true}
		searchBarPlaceholder="Search for games"
	/>
</header>


