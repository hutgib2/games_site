---
import Image from "astro/components/Image.astro";

const { title, image, description, href} = Astro.props;
---

<div class="game-card">
	<div class="thumbnail"><Image src={image} alt=`${title} image`/></div>
	
	<div class="game-info">
		<div>
			<h2>{title}</h2>
			<p class="game-description">{description}</p>
		</div>
	
		<a href={href} class="triangle"></a>
	</div>
</div>


<style>
	.game-card {
		/* ... */
	}

	.thumbnail {
		width: 100%;
		aspect-ratio: 1.6;
		
		img {
			/* display: block; */
			width: 100%;
			height: 100%;
			border-radius: 1rem;
			overflow: hidden;
			object-position: center center;
			object-fit: cover;
		}
	}

	.game-info {
		display: flex;
		width: 100%;
		justify-content: space-between;
		padding: 16px;
	}

	.game-description {
		color: dimgray;
	}

	.triangle {
		width: 0; height: 0;
		border-style: solid;
		border-width: 28px 0px 28px 64px;
		border-color: transparent transparent transparent #02fcd3;
		transform: rotate(0deg);
	}
</style>