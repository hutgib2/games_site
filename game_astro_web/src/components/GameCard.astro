---
import Image from "astro/components/Image.astro";
const { title, image, description } = Astro.props;
---

<div class="game-card">
	<div class="thumbnail"><Image src={image} alt=`${title}-img`/></div>
	<h4>{title}</h4>
	<p class="game-description">{description}</p>
</div>

<style>
	.game-card {
		width: 500px;
		height: auto;
	}

	.thumbnail {
		width: 100%;
		aspect-ratio: 1.6;
		
		img {
			/* display: block; */
			width: 100%;
			height: 100%;
			border-radius: 1rem;
			overflow: hidden;
			object-position: center center;
			object-fit: cover;
		}
	}

	.game-description {
		color: dimgray;
	}
</style>