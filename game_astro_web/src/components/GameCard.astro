---
import Image from 'astro/components/Image.astro';

const { title, image, description, href } = Astro.props;
---

<div class="game-card">
	<div class="thumbnail">
		<Image src={image} alt=`${title} image` />
	</div>

	<div class="game-info">
		<div>
			<h2>{title}</h2>
			<p class="game-description">{description}</p>
		</div>

		<a href={href} class="triangle"> Play </a>
	</div>
</div>

<!-- 
	Make the color of the title change to our brand color on hover
-->

<style>
	.game-card {
		transition:
			transform 0.3s ease,
			color 0.3s ease;
	}

	.game-card:hover {
		color: var(--color-brand);
		transform: scale(1.01);
	}

	.thumbnail {
		width: 100%;
		aspect-ratio: 1.6;

		img {
			/* display: block; */
			width: 100%;
			height: 100%;
			border-radius: 1rem;
			overflow: hidden;
			object-position: center center;
			object-fit: cover;
		}
	}

	.game-info {
		display: flex;
		width: 100%;
		justify-content: space-between;
		padding: var(--gap-5);
	}

	.game-description {
		color: var(--color-text-muted);
	}

	.triangle {
		display: flex;
		align-items: center;
		justify-content: left;

		width: 64px;
		height: 56px;
		padding: 8px;
		clip-path: polygon(0 0, 100% 50%, 0 100%);

		background: var(--color-brand);
		color: var(--color-bg);
		font-weight: bold;
	}

	.play {
		/* position: relative; */
		/* justify-self: left; */
	}
</style>
